{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "python tools/idt_hook_guard.py --event PreToolUse",
        "windows": "python tools\\idt_hook_guard.py --event PreToolUse",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python tools/idt_hook_guard.py --event Stop",
        "windows": "python tools\\idt_hook_guard.py --event Stop",
        "timeout": 15
      }
    ]
  }
}
